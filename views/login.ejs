<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MeowSpace</title>
    <style>
        :root {
            --cream: #fff8ef;
            --cat-brown: #8a5d3b;
            --paw-pink: #ffb7c5;
            --ink: #2c1f17;
        }

        body {
            margin: 0;
            font-family: "Trebuchet MS", "Segoe UI", sans-serif;
            background:
                radial-gradient(circle at 12% 14%, rgba(255, 183, 197, 0.25), transparent 20%),
                radial-gradient(circle at 82% 18%, rgba(200, 159, 117, 0.2), transparent 24%),
                linear-gradient(180deg, #fffdf8 0%, var(--cream) 100%);
            color: var(--ink);
        }

        h1 {
            text-align: center;
            color: #5b3924;
            margin-top: 2rem;
        }

        main {
            max-width: 420px;
            margin: 1rem auto;
            background: #fff;
            border: 1px solid #edd3bd;
            border-radius: 16px;
            padding: 1rem;
            box-shadow: 0 8px 16px rgba(44, 31, 23, 0.07);
        }

        input {
            width: 100%;
            margin: 0.35rem 0 0.55rem;
            border: 1px solid #e5c6a9;
            border-radius: 10px;
            padding: 0.65rem 0.7rem;
            box-sizing: border-box;
            font: inherit;
        }

        button {
            border: 0;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--paw-pink), #ffa3b7);
            color: #5d2a3a;
            font-weight: 800;
            padding: 0.6rem 1rem;
            cursor: pointer;
        }

        a {
            color: #8a5d3b;
            text-decoration: none;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <h1>Login</h1>
    <main>
        <div>
            <p style="color: red;"><%= error %></p>
            <form action="/start" method="post">
                <label>Email</label> <br>
                <input type="text" name="email"> <br>
    
                <label>Password</label> <br>
                <input type="password" name="password"> <br>
                <button type="submit">Login</button>
            </form>
        </div>
        <div>
            <p>Don't have and account?</p>
            <a href="/start/register">
                <button>Register here!</button>
            </a>
        </div>
    </main>
</body>
</html>
